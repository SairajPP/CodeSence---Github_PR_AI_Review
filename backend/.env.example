# ============================================================
# CodeSense Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# 
# NEVER commit .env to git — it contains secrets!
# ============================================================

# --- GitHub Webhook Secret ---
# This is a password you create (any random string).
# You'll enter the SAME value on GitHub when setting up the webhook.
# It's used to verify that incoming requests are really from GitHub.
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# --- GitHub Personal Access Token ---
# Get this from: GitHub → Settings → Developer settings → Personal access tokens
# Needs 'repo' scope (so CodeSense can read PR diffs and post comments)
GITHUB_TOKEN=your_github_pat_here

# --- Groq API Key (Week 2) ---
# Get this from: https://console.groq.com/keys
# Used to power the LangGraph AI agents (Security, Performance, Logic, Style)
GROQ_API_KEY=your_groq_api_key_here
